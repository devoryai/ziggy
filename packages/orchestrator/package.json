{
  "name": "@ziggy/orchestrator",
  "version": "0.1.0",
  "description": "Task orchestration, state machine, and execution engine for Ziggy",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "require": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "db:init": "tsx src/scripts/db-init.ts",
    "db:seed": "tsx src/scripts/db-seed.ts"
  },
  "dependencies": {
    "@ziggy/memory": "workspace:*",
    "@ziggy/models": "workspace:*",
    "@ziggy/policy": "workspace:*",
    "@ziggy/shared": "workspace:*",
    "@ziggy/tools": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
